# ================================================================
# UniConnect — Variables de Entorno Consolidadas
# ================================================================
# Este archivo documenta TODAS las variables de entorno del monorepo.
# Copia las variables relevantes al .env de cada servicio.
#
# ⚠️  IMPORTANTE:
#   - No coloques valores reales en este archivo.
#   - No subas ningún .env con secretos al repositorio.
#   - Cada servicio lee su propio .env (ver env_file en docker-compose.yml).
#   - Las variables marcadas con [COMPARTIDA] se usan en más de un servicio.
# ================================================================


# ================================================================
# SUPABASE — Configuración Cloud
# [COMPARTIDA] entre auth-service, profile-service, social-service,
#              chat-service, dashboard (frontend), mobile (frontend)
# ================================================================

# URL del proyecto en Supabase Cloud (siempre empieza con https://)
SUPABASE_URL=https://your-project-id.supabase.co

# Clave anónima pública (segura para exponer al cliente)
# Usada por: chat-service, dashboard, mobile
SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Service Role Key — SECRETO, nunca expongas al cliente
# Usada por: auth-service, profile-service, social-service, chat-service
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# JWT Secret del proyecto Supabase (para validar tokens internamente)
# Usada por: auth-service, profile-service, social-service
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-at-least-32-characters-long

# Nombre del bucket de Supabase Storage para avatares de usuario
# Usada por: profile-service
SUPABASE_AVATARS_BUCKET=avatars


# ================================================================
# AUTH0 — Proveedor de identidad OAuth2
# [COMPARTIDA] entre auth-service, api-gateway, dashboard, mobile
# ================================================================

# Dominio del tenant de Auth0 (sin https://)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Emisor completo (con https://)
AUTH0_ISSUER=https://your-tenant.us.auth0.com/

# Identificador de la API en Auth0 (audience)
AUTH0_AUDIENCE=https://your-api-audience

# Client ID de la aplicación registrada en Auth0
# auth-service (M2M o Regular Web App):
AUTH0_CLIENT_ID=your-auth0-client-id

# URIs de redirección permitidas para Auth0 (separadas por coma)
# Usada por: auth-service
AUTH0_ALLOWED_REDIRECT_URIS=http://localhost:8081/auth/callback,uniconnect2://auth/callback

# Conexión Auth0 a usar (por defecto Google)
# Usada por: dashboard (frontend)
AUTH0_CONNECTION=google-oauth2


# ================================================================
# API GATEWAY  (./api-gateway/.env)
# Puerto por defecto: 3000
# ================================================================

# Puerto en el que escucha el gateway
PORT=3000

# Entorno de ejecución
NODE_ENV=development

# URLs internas de los microservicios
# Con docker-compose, usar los nombres de servicio (no localhost):
AUTH_SERVICE_URL=http://auth-service:3001
PROFILE_SERVICE_URL=http://profile-service:3002
SOCIAL_SERVICE_URL=http://social-service:3003
CHAT_SERVICE_URL=http://chat-service:3004


# ================================================================
# AUTH SERVICE  (./auth-service/.env)
# Puerto por defecto: 3001
# ================================================================

PORT=3001
NODE_ENV=development

# Dominio institucional permitido para registro (ej: ucaldas.edu.co)
ALLOWED_DOMAIN=your-institution.edu.co

# URL pública del backend (usada para redireccionamientos externos)
# En desarrollo local con ngrok o similar
BACKEND_PUBLIC_URL=https://your-ngrok-or-tunnel-url.dev

# Orígenes CORS permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:5173

# Activa validación de token al sincronizar usuario (true | false)
REQUIRE_AUTH_SYNC_TOKEN=false


# ================================================================
# PROFILE SERVICE  (./profile-service/.env)
# Puerto por defecto: 3002
# ================================================================

PORT=3002
NODE_ENV=development

# URL pública del backend (para URLs firmadas de avatares)
BACKEND_PUBLIC_URL=https://your-ngrok-or-tunnel-url.dev


# ================================================================
# SOCIAL SERVICE  (./social-service/.env)
# Puerto por defecto: 3003
# ================================================================

PORT=3003
NODE_ENV=development

# URL pública del backend (para webhooks o redirecciones externas)
BACKEND_PUBLIC_URL=https://your-ngrok-or-tunnel-url.dev


# ================================================================
# CHAT SERVICE  (./chat-service/.env)
# Puerto por defecto: 3004
# ================================================================

PORT=3004
NODE_ENV=development

# Orígenes CORS permitidos para WebSocket (separados por coma)
CORS_ORIGIN=http://localhost:5173,http://localhost:8081,http://localhost:19006


# ================================================================
# DASHBOARD FRONTEND — React + Vite
# (../UNICONNECT_6_Dashboard_Frontend/.env)
# Puerto de desarrollo: 5173
# Todas las variables deben llevar prefijo VITE_ para ser expuestas
# al bundle del navegador (Vite las inyecta en tiempo de build).
# ================================================================

# URL base del API Gateway — apuntada desde el navegador (no Docker)
VITE_API_BASE_URL=http://localhost:3000/api

# URL pública del backend para recursos externos
VITE_BACKEND_PUBLIC_URL=http://localhost:3000

# Auth0
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
VITE_AUTH0_AUDIENCE=https://your-api-audience
VITE_AUTH0_CONNECTION=google-oauth2
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/auth/callback

# Endpoints internos expuestos via gateway
VITE_AUTH_SYNC_URL=http://localhost:3000/auth/sync
VITE_AUTH_SESSION_URL=http://localhost:3000/auth/session

# Chat Service — accedido directamente por WebSocket desde el navegador
VITE_CHAT_SERVICE_URL=http://localhost:3004

# Supabase (clave pública, segura para el cliente)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ================================================================
# MOBILE FRONTEND — React Native + Expo
# (../UNICONNECT_2_Frontend/.env)
# Las variables públicas deben llevar prefijo EXPO_PUBLIC_ para ser
# accesibles en el bundle (Expo las inyecta en tiempo de build).
# ================================================================

# Supabase (pública)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Auth0
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-auth0-native-client-id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://your-api-audience

# URLs de backend expuestas al bundle de Expo
EXPO_PUBLIC_AUTH_SYNC_URL=http://localhost:3000/auth/sync
EXPO_PUBLIC_CHAT_SERVICE_URL=http://localhost:3004

# Google OAuth (Client IDs por plataforma)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_EXPO=your-google-expo-client-id.apps.googleusercontent.com

# CORS (lado servidor — no requerido en el bundle)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173,https://auth.expo.io
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_ALLOWED_REDIRECT_URIS=https://auth.expo.io/@your-username/uniconnect_2,uniconnect2://auth/callback

# Solo para pruebas locales — NO usar en producción
REQUIRE_AUTH_SYNC_TOKEN=false
