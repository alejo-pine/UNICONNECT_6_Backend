# Auth Service Environment Variables

# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Application Settings (Required)
PORT=3001
NODE_ENV=development
ALLOWED_DOMAIN=ucaldas.edu.co

# Backend Configuration (Optional)
BACKEND_PUBLIC_URL=http://localhost:3001

# CORS Configuration (Optional, default: http://localhost:3001)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,https://yourdomain.com

# Auth0 Configuration (Optional - required if using Auth0)
AUTH0_DOMAIN=dev-yourapp.us.auth0.com
AUTH0_ISSUER=https://dev-yourapp.us.auth0.com/
AUTH0_AUDIENCE=https://your-api-audience
AUTH0_ALLOWED_REDIRECT_URIS=https://yourdomain.com/callback,app://auth/callback

# Other Settings (Optional)
REQUIRE_AUTH_SYNC_TOKEN=false
