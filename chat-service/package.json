{
  "name": "ms-chat",
  "version": "1.0.0",
  "description": "Uniconnect Communication Microservice",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "npx kill-port 3004 && tsx watch src/index.ts",
    "build": "npm run build:openapi && tsc",
    "build:openapi": "tsx src/scripts/generate-openapi.ts",
    "start:prod": "node dist/index.js",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "axios": "^1.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
